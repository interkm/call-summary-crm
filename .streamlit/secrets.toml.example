# ───────────────────────────────────────────────
# 이 파일을 복사해서 .streamlit/secrets.toml 로 저장하고
# 실제 값을 채워넣으세요. secrets.toml은 git에 올라가지 않습니다.
# ───────────────────────────────────────────────

# ① 텔레그램 봇
# 1. @BotFather 에서 /newbot → 토큰 발급
# 2. 봇에게 메시지 1개 보내고
#    https://api.telegram.org/bot<TOKEN>/getUpdates 접속
#    → "chat":{"id": 숫자} 가 CHAT_ID
TELEGRAM_BOT_TOKEN = "1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TELEGRAM_CHAT_ID   = "123456789"

# ② Groq Whisper API (한국어 전사, 무료, 강력 추천)
# console.groq.com → API Keys → Create API Key
GROQ_API_KEY = "gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ③ OpenRouter API (LLM 요약, 선택)
# https://openrouter.ai/keys 에서 발급
OPENROUTER_API_KEY = "sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ③ GitHub Gist (스케줄 다이제스트 카운터, 선택)
# 1. github.com/settings/tokens 에서 PAT 생성 (scope: gist)
# 2. 앱 실행 후 사이드바 "Gist 생성" 버튼 클릭 → ID 자동 발급
GITHUB_TOKEN = "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GIST_ID      = ""   # 앱 실행 후 자동 채워짐
